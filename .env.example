# Copy to .env to enable Live AI mode. Leave unset to run in Demo mode.
# The key is read server-side only (Vite middleware / Express) and is never
# exposed to the browser.
ANTHROPIC_API_KEY=

# Optional: override the model used by the live proxy.
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional: production server port (defaults to 3000).
PORT=3000
